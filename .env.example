# ─────────────────────────────────────────────────────────────────────────────
# Saan-hub Solutions — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── EmailJS (Contact Form) ────────────────────────────────────────────────────
# 1. Sign up at https://www.emailjs.com (free plan)
# 2. Create a Service (Gmail/Outlook) → copy the Service ID
# 3. Create an Email Template → copy the Template ID
# 4. Go to Account → API Keys → copy Public Key
VITE_EMAILJS_SERVICE_ID=service_nh4lmmp
VITE_EMAILJS_TEMPLATE_ID=template_iuxj306
VITE_EMAILJS_PUBLIC_KEY=stP86Hg15kOLVFMfmi2I_

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# 1. Go to https://analytics.google.com → Create Property
# 2. Get your Measurement ID (starts with G-)
VITE_GA_MEASUREMENT_ID=G-LQWV6DENF3

# ── n8n Webhook (AI Chatbot — optional) ──────────────────────────────────────
# Only needed if you want to route chatbot queries through an n8n AI workflow.
# The chatbot works fully without this (falls back to built-in knowledge base).
# Format: https://your-n8n-instance.com/webhook/your-workflow-id
# VITE_N8N_WEBHOOK_URL=
